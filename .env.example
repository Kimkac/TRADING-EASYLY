# Example environment variables
# Copy this to .env and fill in your actual values

# Alpaca API Credentials
API_KEY=your_alpaca_api_key_here
API_SECRET=your_alpaca_api_secret_here

# Trading Settings
SYMBOL=AAPL
QUANTITY=100
TRADING_MODE=paper  # 'paper' for testing, 'live' for real money

# Strategy Settings
SHORT_WINDOW=5
LONG_WINDOW=20
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Database (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/trading_db

# API Settings
API_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=5
